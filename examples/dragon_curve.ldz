    zwroc 0
  }
  zwroc -9999
}

*/

funkcja dragon(rozmiar, poziom, d){
  jesli poziom == 0 {
    x = x - cos(kat) * rozmiar
    y = y + sin(kat) * rozmiar
    pokazl("line " + x + " " + y)
  }
  albo{
    dragon(rozmiar / 1.4142135624, poziom - 1, 1)
    kat = kat - d * 90
    dragon(rozmiar / 1.4142135624, poziom - 1, -1)
  }
}



dragon(60, 12, 1)
